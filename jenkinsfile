pipeline{
    agent any
    stages{
        stage('Deployment'){
            steps{
                sh """
                scp docker-compose.yaml ubuntu@15.206.67.30:/home/ubuntu/
                ssh ubuntu@15.206.67.30 '''
                cd /home/ubuntu
                docker-compose down
                docker-compose up -d
                '''
                """
            }
        }
    }
}